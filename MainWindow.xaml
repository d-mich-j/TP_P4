<Window x:Class="GestorProductosWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestorProductosWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="0,0,0,-6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="39*"/>
            <ColumnDefinition Width="361*"/>
        </Grid.ColumnDefinitions>
        <TabControl Grid.ColumnSpan="2" Margin="0,0,0,10">
            <TabItem Header="Inventario">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="#FFE49DA4" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid Background="#FF34CFDA">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="111*"/>
                        <ColumnDefinition Width="683*"/>
                    </Grid.ColumnDefinitions>
                    <DataGrid x:Name="dataGridProductos" d:ItemsSource="{d:SampleData ItemCount=5}" Grid.ColumnSpan="2" Background="#FF984C4C" Margin="-10,0,10,0"/>
                    <Button x:Name="btnAgregar" Grid.Column="1" Content="Agregar" HorizontalAlignment="Left" Margin="520,212,0,0" VerticalAlignment="Top" Height="46" Width="137" Background="#FFD88C8C" Click="btnAgregar_Click"/>
                    <Button x:Name="btnEliminar" Content="Eliminar" HorizontalAlignment="Left" Margin="26,201,0,0" VerticalAlignment="Top" Grid.ColumnSpan="2" Height="57" Width="156" Background="#FFD88C8C" Click="btnEliminar_Click_1"/>
                </Grid>
            </TabItem>
            <TabItem Header="Busqueda">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="#FFA9C2E4" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid Background="#FF6A98D6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="19*"/>
                        <ColumnDefinition Width="773*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="comboTipoBusqueda" Grid.Column="2" HorizontalAlignment="Left" Margin="222,20,0,0" VerticalAlignment="Top" Width="491" Height="34"/>
                    <TextBox x:Name="txtBusqueda" Grid.Column="2" HorizontalAlignment="Left" Margin="222,59,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="491" Height="55"/>
                    <Button x:Name="btnBuscar" Grid.Column="2" Content="Buscar" HorizontalAlignment="Left" Margin="566,119,0,0" VerticalAlignment="Top" Height="35" Width="147" Click="btnBuscar_Click_1"/>
                    <TextBlock x:Name="txtResultadoBusqueda" Grid.Column="2" HorizontalAlignment="Left" Margin="222,180,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Height="135" Width="491"/>
                    <ProgressBar x:Name="iteraciones" Grid.Column="2" HorizontalAlignment="Left" Height="42" Margin="101,330,0,0" VerticalAlignment="Top" Width="662"/>
                </Grid>
            </TabItem>
            <TabItem Header="Ordenamiento">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="#FFE2D8FD" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid Background="#FF8D82AB">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24*"/>
                        <ColumnDefinition Width="69*"/>
                        <ColumnDefinition Width="701*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="comboCriterioOrden" HorizontalAlignment="Left" Margin="185,10,0,0" VerticalAlignment="Top" Width="468" Height="41" Grid.Column="2">
                        <ComboBox.Background>
                            <LinearGradientBrush EndPoint="0,1">
                                <GradientStop Color="#FFF0F0F0"/>
                                <GradientStop Color="#FFB5B5B5" Offset="1"/>
                            </LinearGradientBrush>
                        </ComboBox.Background>
                    </ComboBox>
                    <Button x:Name="btnOrdenar" Content="Ordenar" HorizontalAlignment="Left" Margin="412,74,0,0" VerticalAlignment="Top" Height="51" Width="241" Background="#FFD9C7E4" Grid.Column="2" Click="btnOrdenar_Click_1"/>
                    <ListView x:Name="listViewOrdenados" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="12,74,495,53" Background="#FFC8C4E0" Grid.ColumnSpan="2" Grid.Column="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <Canvas x:Name="canvasGrafico" Margin="240,141,48,53" Grid.Column="2">
                        <Rectangle Height="136" Canvas.Left="10" Stroke="Black" Canvas.Top="36" Width="41" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    </Canvas>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>