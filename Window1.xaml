<Window x:Class="Gestor_de_Productos_WTF.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gestor_de_Productos_WTF"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="800">
    <Grid Background="#FFB15454">
        <TextBox x:Name="txtId" HorizontalAlignment="Left" Margin="45,41,0,0" TextWrapping="Wrap" Text="Id" VerticalAlignment="Top" Width="302" Height="39" Background="#FFA51818" FontSize="20"/>
        <TextBox x:Name="txtCodigoBarras" HorizontalAlignment="Left" Margin="45,97,0,0" TextWrapping="Wrap" Text="Codigo de Barras" VerticalAlignment="Top" Width="302" Height="39" Background="#FFA51818" FontSize="20"/>
        <TextBox x:Name="txtNombre" HorizontalAlignment="Left" Margin="45,162,0,0" TextWrapping="Wrap" Text="Nombre" VerticalAlignment="Top" Width="302" Height="39" Background="#FFA51818" FontSize="20"/>
        <TextBox x:Name="txtCtagorias" HorizontalAlignment="Left" Margin="45,228,0,0" TextWrapping="Wrap" Text="Categorias" VerticalAlignment="Top" Width="302" Height="39" Background="#FFA51818" FontSize="20"/>
        <TextBox x:Name="txtPrecio" HorizontalAlignment="Left" Margin="45,298,0,0" TextWrapping="Wrap" Text="Precio" VerticalAlignment="Top" Width="302" Height="39" Background="#FFA51818" FontSize="20"/>
        <TextBox x:Name="txtStock" HorizontalAlignment="Left" Margin="45,363,0,0" TextWrapping="Wrap" Text="Stock" VerticalAlignment="Top" Width="302" Height="39" Background="#FFA51818" FontSize="20"/>
        <Button x:Name="btnGuardar" Content="Guardar" HorizontalAlignment="Left" Margin="583,282,0,0" VerticalAlignment="Top" Height="70" Width="160" Click="btnGuardar_Click" Background="#FFDC9A9A"/>

    </Grid>
</Window>
